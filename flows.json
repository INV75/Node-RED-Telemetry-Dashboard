    {
        "id": "f848155ba2c5c75c",
        "type": "function",
        "z": "70a4eb346241f12a",
        "name": "Telemetry Splitter",
        "func": "// Safely unpack incoming data strings into structured JSON\nvar data = (typeof msg.payload === 'string') ? JSON.parse(msg.payload) : msg.payload;\n\n// Separate your single combined stream into distinct data outputs\nvar outDate = { payload: data.date };\nvar outTime = { payload: data.time };\nvar outLat = { payload: data.lat };\nvar outLon = { payload: data.lon };\nvar outRPM = { payload: data.rpm };\nvar outSpeed = { payload: data.speed };\nvar outCoolant = { payload: data.coolant };\n\n// Map-formatted tracking tracker packet\nvar outMap = {\n    payload: {\n        name: \"Vehicle_01\",\n        lat: data.lat,\n        lon: data.lon,\n        icon: \"car\",\n        iconColor: \"red\",\n        line: \"red\" // This forces the engine to draw a permanent trailing route trace line\n    }\n};\n\n// Send outputs sequentially out of the 8 right-side dots\nreturn [outDate, outTime, outLat, outLon, outRPM, outSpeed, outCoolant, outMap];",
        "outputs": 8,
        "timeout": "0",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 590,
        "y": 400,
