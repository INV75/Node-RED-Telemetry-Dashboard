    {
        "id": "7966dee96eec7ef6",
        "type": "function",
        "z": "70a4eb346241f12a",
        "name": "function 1",
        "func": "// Extract the data from the incoming Python payload\nlet data = msg.payload;\n\n// 1. Format for the Speed Gauge\nlet msgSpeed = { payload: data.speed };\n\n// 2. Format for the RPM Gauge\nlet msgRPM = { payload: data.rpm };\n\n// 3. Format for the Coolant Temp Chart/Gauge\nlet msgTemp = { payload: data.temp };\n\n// 4. Format for the Worldmap Node\nlet msgMap = {\n    payload: {\n        name: \"Curvv\",\n        lat: data.lat,\n        lon: data.lon,\n        icon: \"car\",\n        iconColor: \"blue\"\n    }\n};\n\n// Send to 4 different physical outputs\nreturn [msgSpeed, msgRPM, msgTemp, msgMap];",
        "outputs": 4,
        "timeout": 0,
